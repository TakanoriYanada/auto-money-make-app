# =============================================================================
# AI比較ナビ — 環境変数テンプレート
# このファイルをコピーして .env.local を作成し、各値を設定してください
# =============================================================================

# サイトURL（本番ドメイン。末尾スラッシュなし）
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# =============================================================================
# アフィリエイトID（docs/REVENUE_MODEL.md を参照して取得してください）
# =============================================================================

# A8.net 会員ID
# 取得先: https://www.a8.net/
AFFILIATE_ID_A8=

# バリューコマース パブリッシャーID
# 取得先: https://www.valuecommerce.com/
AFFILIATE_ID_VC=

# もしもアフィリエイト パートナーID
# 取得先: https://af.moshimo.com/
AFFILIATE_ID_MOSHIMO=

# =============================================================================
# Google AdSense（サイト公開後、月間PV 3000超えたら申請）
# =============================================================================

# Google AdSense Publisher ID（形式: ca-pub-XXXXXXXXXX）
# 取得先: https://adsense.google.com/
NEXT_PUBLIC_ADSENSE_ID=

# =============================================================================
# Google Search Console（サイトマップ送信・検索順位分析）
# =============================================================================

# Google Site Verification トークン（HTMLタグ方式の content 値のみ）
# 例: "abcd1234...xyz"
# 取得手順: docs/GOOGLE_SEARCH_CONSOLE.md を参照
GOOGLE_SITE_VERIFICATION=
